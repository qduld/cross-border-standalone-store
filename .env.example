# ============================================
# Craft Shop Environment Variables
# ============================================

# Database Connection (Required)
# Get this from Zeabur PostgreSQL service or your PostgreSQL provider
DATABASE_URL="postgresql://postgres:password@localhost:5432/craftshop"

# Site Configuration
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Stripe Payment Integration
# Get these from: https://dashboard.stripe.com/apikeys
# Test keys for development:
STRIPE_SECRET_KEY="sk_test_YOUR_STRIPE_SECRET_KEY"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_YOUR_STRIPE_PUBLISHABLE_KEY"
STRIPE_WEBHOOK_SECRET="whsec_YOUR_WEBHOOK_SECRET"

# Live keys for production (use only when ready):
# STRIPE_SECRET_KEY="sk_live_YOUR_STRIPE_SECRET_KEY"
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_YOUR_STRIPE_PUBLISHABLE_KEY"

# Admin Credentials (for backend access)
ADMIN_EMAIL="admin@craftshop.com"
ADMIN_PASSWORD="change_this_password_in_production"

# Node Environment
NODE_ENV="development"

# Optional: Email Configuration (for order notifications)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASSWORD="your-app-password"
# EMAIL_FROM="noreply@craftshop.com"

# Optional: Image Storage
# For Cloudflare R2:
# R2_ACCOUNT_ID="your_account_id"
# R2_ACCESS_KEY_ID="your_access_key"
# R2_SECRET_ACCESS_KEY="your_secret_key"
# R2_BUCKET_NAME="craft-shop-images"
# R2_PUBLIC_URL="https://your-r2-domain.com"